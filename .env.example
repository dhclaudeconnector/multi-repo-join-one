# ==============================================================================
# multi-repo-join-one - ENV example
# ==============================================================================
# Quy ước:
# - Các biến JSON có thể dùng JSON thô hoặc base64(JSON). Production nên dùng base64.
# - Boolean hợp lệ: true|false|1|0|yes|no|on|off.
# - Provider hợp lệ: github | azure.
# - SYNC_MODE hiện hỗ trợ thực tế: squash. replay là reserved/chưa implement đủ lịch sử.
# - Không commit token thật. Placeholder token bên dưới cố tình KHÔNG giống token thật để
#   tránh GitHub secret scanning chặn push.
# ============================================================================== 

# ------------------------------------------------------------------------------
# Firebase RTDB queue
# ------------------------------------------------------------------------------
# URL Realtime Database. Dạng production thường là:
#   https://<project-id>-default-rtdb.firebaseio.com
# Dạng emulator/local test:
#   http://127.0.0.1:9000?ns=<project-id>
FIREBASE_DB_URL="https://your-project-id-default-rtdb.firebaseio.com"

# Service account để Node đọc/ghi trạng thái queue.
# Chấp nhận 1 trong 3 dạng:
#   1) path file JSON: /run/secrets/firebase-service-account.json
#   2) JSON thô: {"type":"service_account",...}
#   3) base64(JSON) - khuyến nghị cho CI/CD secret
# Lấy ở Firebase Console > Project settings > Service accounts > Generate new private key.
FIREBASE_SERVICE_ACCOUNT="/path/to/firebase-service-account.json"

# Path queue trong RTDB. Webhook GitHub POST vào URL:
#   https://<db>.firebaseio.com/sync-queue.json?auth=<RTDB_WEBHOOK_AUTH_TOKEN>
RTDB_QUEUE_PATH="/sync-queue"

# Khi item done/skipped:
#   false = giữ nguyên/dọn theo backend hiện tại
#   true  = move sang archive nếu backend hỗ trợ
ARCHIVE_DONE="false"

# ------------------------------------------------------------------------------
# Targets - repo đích nhận code từ mọi repo nguồn hợp lệ
# ------------------------------------------------------------------------------
# JSON array. Mỗi item:
#   provider: github | azure
#   repo:     github: owner/repo, azure: organization/project/_git/repo hoặc org/repo theo remote bạn dùng
#   branch:   branch đích
# Ví dụ JSON thô:
TARGETS='[{"provider":"github","repo":"your-username/personal-mono","branch":"main"},{"provider":"azure","repo":"your-azure-org/your-project/_git/your-azure-repo","branch":"main"}]'
# Ví dụ base64(JSON) tương đương, dùng cho prod/CI:
# TARGETS="W3sicHJvdmlkZXIiOiJnaXRodWIiLCJyZXBvIjoieW91ci11c2VybmFtZS9wZXJzb25hbC1tb25vIiwiYnJhbmNoIjoibWFpbiJ9LHsicHJvdmlkZXIiOiJhenVyZSIsInJlcG8iOiJ5b3VyLWF6dXJlLW9yZy95b3VyLXByb2plY3QvX2dpdC95b3VyLWF6dXJlLXJlcG8iLCJicmFuY2giOiJtYWluIn1d"

# ------------------------------------------------------------------------------
# Source filtering
# ------------------------------------------------------------------------------
# EXCLUDE_REPOS: repo khớp bất kỳ rule nào sẽ bị bỏ qua.
# INCLUDE_REPOS: nếu rỗng => cho phép mọi repo trừ exclude. Nếu không rỗng => chỉ sync repo khớp include.
# type hợp lệ: startsWith | endsWith | equal
# value có thể là tên repo "svc-api" hoặc fullName "org/svc-api".
EXCLUDE_REPOS='[{"type":"startsWith","value":"test-"},{"type":"endsWith","value":"-sandbox"},{"type":"equal","value":"your-org/playground"}]'
INCLUDE_REPOS='[]'

# ------------------------------------------------------------------------------
# Token fallback: repo -> org -> provider global -> default
# ------------------------------------------------------------------------------
# Tên biến sẽ được normalize uppercase, dấu '-' đổi thành '_'.
# Ví dụ org "my-org", repo "svc-api": TOKEN__GITHUB__MY_ORG__SVC_API
#
# Scope GitHub token cần có:
# - Source private repo: Contents read.
# - Target repo: Contents read/write.
# - Nếu bootstrap tạo webhook org: admin:org_hook hoặc Organization webhooks write.
#
# Scope Azure PAT cần có:
# - Code Read cho source nếu dùng Azure source.
# - Code Read & Write cho target Azure repo.
#
# Không dùng token thật trong file mẫu. Dạng placeholder được tách/sai format để tránh secret scanning.
TOKEN__DEFAULT=""
TOKEN__GITHUB="""PASTE_GITHUB_PAT_OR_FINE_GRAINED_TOKEN_HERE"""
TOKEN__AZURE="""PASTE_AZURE_DEVOPS_PAT_HERE"""
# TOKEN__GITHUB__YOUR_ORG="""PASTE_ORG_LEVEL_GITHUB_TOKEN_HERE"""
# TOKEN__GITHUB__YOUR_ORG__SVC_API="""PASTE_REPO_LEVEL_GITHUB_TOKEN_HERE"""
# TOKEN__AZURE__YOUR_AZURE_ORG="""PASTE_AZURE_ORG_LEVEL_PAT_HERE"""

# ------------------------------------------------------------------------------
# Sync behaviour
# ------------------------------------------------------------------------------
# Giá trị hợp lệ: squash | replay
# Lưu ý: code hiện tại thực tế dùng squash snapshot; replay chưa giữ lịch sử commit gốc đầy đủ.
SYNC_MODE="squash"

# Số target xử lý song song trong cùng một queue item. Giá trị khuyến nghị: 1..5.
TARGET_CONCURRENCY="3"

# Shallow clone depth. 1 = nhanh nhất, đủ cho snapshot theo afterSha.
CLONE_DEPTH="1"

# Retry clone/fetch/push.
CLONE_MAX_RETRIES="3"
CLONE_RETRY_BACKOFF_MS="2000"

# Commit message template. Biến hỗ trợ:
# {message}, {sourceRepo}, {shortSha}, {sha}, {provider}, {pusherName}, {pusherEmail},
# {authorName}, {authorEmail}, {ref}, {branch}
COMMIT_MESSAGE_TEMPLATE="{message}\n\nSynced-From: {sourceRepo}@{shortSha}\nProvider: {provider}\nPushed-By: {pusherName} <{pusherEmail}>\nOriginal-Author: {authorName} <{authorEmail}>\nRef: {ref}"

# Work dir tạm. GitHub Actions nên dùng $RUNNER_TEMP/repo-sync, Azure dùng $(Agent.TempDirectory)/repo-sync.
WORK_DIR="/tmp/repo-sync"

# ------------------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------------------
# LOG_LEVEL hợp lệ: trace | debug | info | warn | error | silent
LOG_LEVEL="trace"
# LOG_FORMAT hợp lệ: json | pretty
LOG_FORMAT="json"
# true chỉ dùng debug local vì payload có thể chứa thông tin nhạy cảm.
LOG_INCLUDE_PAYLOAD="false"

# ------------------------------------------------------------------------------
# Bootstrap/API helper variables, không bắt buộc cho service runtime
# ------------------------------------------------------------------------------
# GitHub org chứa các repo nguồn. Script bootstrap sẽ tạo webhook ở cấp org.
GITHUB_SOURCE_ORG="your-org"
# RTDB webhook endpoint đầy đủ để GitHub POST thẳng vào queue.
# Ví dụ: https://your-project-id-default-rtdb.firebaseio.com/sync-queue.json?auth=YOUR_DATABASE_SECRET_OR_TOKEN
RTDB_WEBHOOK_URL="https://your-project-id-default-rtdb.firebaseio.com/sync-queue.json?auth=PASTE_Rtdb_Write_Token"
# Token dùng để gọi GitHub API tạo org webhook/set secrets. Không cần dùng runtime nếu đã cấu hình xong.
GITHUB_ADMIN_TOKEN="""PASTE_GITHUB_ADMIN_TOKEN_FOR_WEBHOOK_AND_SECRETS"""

# Azure bootstrap helper.
AZURE_DEVOPS_ORG="your-azure-org"
AZURE_DEVOPS_PROJECT="your-project"
AZURE_PIPELINE_NAME="multi-repo-join-one"

# Output check helper: danh sách repo nguồn muốn so sánh với target sau khi chạy.
# Service runtime không dùng biến này.
CHECK_SOURCE_REPOS='[{"provider":"github","repo":"your-org/svc-api","branch":"main"},{"provider":"github","repo":"your-org/svc-web","branch":"main"}]'
